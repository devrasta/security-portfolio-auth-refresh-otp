meta {
  name: 2fa-status
  type: http
  seq: 3
}

get {
  url: {{api_url}}/auth/2fa/status
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  # Statut 2FA

  Retourne si le 2FA est active sur le compte de l'utilisateur connecte.

  **Requiert** : JwtAuthGuard (Bearer token)

  **Throttling** : exempt (SkipThrottle)

  **Reponse** :
  - `isEnabled` : `true` si le 2FA est active, `false` sinon
}

settings {
  encodeUrl: true
  timeout: 0
}
