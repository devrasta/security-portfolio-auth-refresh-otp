# Application
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5174

# Database (Prisma connection string)
DATABASE_URL=postgresql://auth_user:CHANGE_THIS_SECURE_PASSWORD@localhost:5432/auth_db

# JWT
JWT_SECRET=CHANGE_THIS_TO_RANDOM_STRING_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_STRING
JWT_EXPIRES_IN=60s

# Security
ENCRYPTION_KEY=CHANGE_THIS_TO_64_HEX_CHARS_AES256_KEY
COOKIE_SECRET=CHANGE_THIS_SECURE_COOKIE_SECRET
